SECRET_KEY=secret
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=event_management_system
DB_USER=user
DB_PASSWORD=password
DB_HOST=127.0.0.1   # use "db" when running inside Docker (set in docker-compose.yml)
DB_PORT=5432

# Django settings module
# Use "event_management_system.settings.development" for local dev without Docker
DJANGO_SETTINGS_MODULE=event_management_system.settings.production

# Tailwind / npm
# Windows local dev: set to full path, e.g. C:\Program Files\nodejs\npm.cmd
# Docker / Linux: leave as "npm"
NPM_BIN_PATH=npm

# SSL — set True only if Django is the SSL endpoint (not behind a proxy)
SECURE_SSL_REDIRECT=False
